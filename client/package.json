    "react-icons": "^4.10.1",
    "serve": "^14.2.5",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  }
